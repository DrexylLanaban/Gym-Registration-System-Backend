# Copy to .env for local dev. On Render (or any host), set the same keys in the dashboard — never commit real passwords.

PORT=5000

# Remote MySQL (e.g. InfinityFree: host from Control Panel → MySQL)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Lower this on free MySQL (e.g. 3–5) to avoid “too many connections”
DB_CONNECTION_LIMIT=5

# If the host requires TLS, set DB_SSL=true (InfinityFree: try without first; enable if connections fail)
# DB_SSL=true

# Optional: ms to wait when opening a connection to a slow remote host (default 20000)
# DB_CONNECT_TIMEOUT_MS=20000
